{
  "compilerOptions": {

    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    
    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },

  "include": ["src"]
}